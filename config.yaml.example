server:
  port: "8080"

database:
  dsn: "fixloop:password@tcp(127.0.0.1:3306)/fixloop_dev?parseTime=true&charset=utf8mb4"

security:
  # 64-char hex string = 32 bytes for AES-256-GCM
  aes_key: "0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20"
  # at least 32 characters
  jwt_secret: "your-jwt-secret-at-least-32-characters-long"

github:
  client_id: "your_github_oauth_app_client_id"
  client_secret: "your_github_oauth_app_client_secret"
  redirect_url: "http://localhost:8080/api/v1/auth/github/callback"

sentry:
  dsn: ""

app:
  base_url: "http://localhost:8080"

tg:
  bot_token: ""
  bot_username: ""

r2:
  account_id: ""
  access_key_id: ""
  secret_access_key: ""
  bucket_name: ""  # defaults to "fixloop-screenshots-prod" when empty
